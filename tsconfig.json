{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitReturns": true,
    "exactOptionalPropertyTypes": true,
    "lib": [
      "ES2020",
      "DOM"
    ],
    "baseUrl": "./src",
    "paths": {
      "@types/*": [
        "types/*"
      ],
      "@core/*": [
        "core/*"
      ],
      "@content/*": [
        "content/*"
      ],
      "@rendering/*": [
        "rendering/*"
      ],
      "@api/*": [
        "api/*"
      ]
    },
    "skipLibCheck": true,
    "types": [
      "vite/client"
    ]
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}